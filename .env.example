# Mini Bloomberg Terminal | environment variables
# Copy to .env and fill in. NEVER commit the real .env.

# -----------------------------------------------------------------
# REQUIRED in production (Railway)
# -----------------------------------------------------------------

# Financial Modeling Prep | market data (quotes, prices, fundamentals, options).
# Sign up at https://site.financialmodelingprep.com/developer/docs
# Starter tier is 750 req/min and covers everything the terminal needs.
FMP_API_KEY=

# FRED | macro time series (Treasury yields, credit spreads, VIX history)
# Sign up at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# -----------------------------------------------------------------
# OPTIONAL | auto enables LLM memo synthesis in Research workspace
# -----------------------------------------------------------------

# Anthropic | Claude API for the Research memo. If absent, the app
# runs fully in deterministic mode and the Research page shows an
# "LLM synthesis unavailable" notice.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------
# APP MODE
# -----------------------------------------------------------------

# "production" (default): FMP + FRED. No yfinance. SQLite persistence.
# "development":          yfinance allowed with DEV MODE banner. JSON fallback.
APP_MODE=production

# -----------------------------------------------------------------
# FUTURE (not wired in v1)
# -----------------------------------------------------------------

# Polygon.io | future upgrade path. Interface ready in
# terminal/data/provider_polygon.py but not wired. Setting this does
# nothing until the provider is implemented.
# POLYGON_API_KEY=
